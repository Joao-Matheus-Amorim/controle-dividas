# FamilyFinance environment variables
# Copy this file to .env.local for local development.
# Keep real secrets out of Git.

# ============================================================
# APP / RUNTIME
# ============================================================
# Current environment name used by humans/logs. Optional today.
APP_ENV=local

# Public app URL. Optional today, useful for auth redirects, emails and future links.
# Local example: http://localhost:3000
# Production example: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel automatically provides VERCEL_URL in deployments.
# Do not set locally unless you have a specific reason.
VERCEL_URL=

# ============================================================
# SUPABASE - PUBLIC BROWSER VARIABLES
# ============================================================
# Required.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Required: use at least one public key below.
# The code supports ANON_KEY and PUBLISHABLE_KEY fallback.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ============================================================
# SUPABASE - PRIVATE SERVER VARIABLES
# ============================================================
# Required for:
# - authorized first access
# - linking auth.users to profiles
# - server-side permission resolution that bypasses RLS safely
# NEVER prefix this with NEXT_PUBLIC_.
# Supabase: Project Settings -> API -> service_role / secret key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_or_secret_key

# ============================================================
# FAMILY ADMIN BOOTSTRAP
# ============================================================
# Required.
# First Admin email allowed to bootstrap/manage the family.
ADMIN_EMAIL=admin@example.com

# ============================================================
# AUTH / EMAIL INVITES - PLANNED
# ============================================================
# Optional today. Use later when implementing invitation emails,
# resend invite, passwordless links, or first-access emails.
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=FamilyFinance <noreply@example.com>

# ============================================================
# FINANCIAL MARKET DATA - PLANNED INVESTMENTS/STOCKS MODULES
# ============================================================
# Optional today. Use later for investments, stocks, real-time prices,
# charts, portfolio evolution and exchange rates.
MARKET_DATA_PROVIDER=none
BRAPI_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
EXCHANGE_RATE_API_KEY=

# ============================================================
# FEATURE FLAGS - PLANNED
# ============================================================
# Optional today. Useful to turn modules on/off safely while developing.
ENABLE_FIXED_EXPENSES_MODULE=false
ENABLE_INVESTMENTS_MODULE=false
ENABLE_STOCKS_MODULE=false
ENABLE_REPORT_EXPORTS=false
ENABLE_EMAIL_INVITES=false

# Public feature flags, only if the frontend needs to know.
# Keep non-sensitive only.
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_INVESTMENTS_MODULE=false
NEXT_PUBLIC_ENABLE_STOCKS_MODULE=false
NEXT_PUBLIC_ENABLE_AI_COMMAND_BAR=false

# ============================================================
# AI / FINANCE ASSISTANT - OPENROUTER
# ============================================================
# Required only when ENABLE_AI_FINANCE_PROVIDER=true.
# See lib/ai/provider/openrouter.ts for model configuration.
ENABLE_AI_FINANCE_PROVIDER=false
OPENROUTER_API_KEY=

# ============================================================
# BILLING / STRIPE - PRE-RUNTIME CONFIGURATION BOUNDARY
# ============================================================
# Keep disabled by default until checkout runtime is implemented.
ENABLE_STRIPE_CHECKOUT=false

# Required only when ENABLE_STRIPE_CHECKOUT=true.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================================
# MOBILE / EXPO - PLANNED NATIVE APP
# ============================================================
# Optional today. Use later when React Native + Expo becomes active.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_ACCESS_TOKEN=

# ============================================================
# NOTES
# ============================================================
# Required for current app to run locally:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - ADMIN_EMAIL
#
# Never commit .env.local.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser.
